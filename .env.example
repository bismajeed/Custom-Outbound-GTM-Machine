# Copy this file to .env and fill in your own keys.
# `.env` is gitignored — never commit real keys.

# --- Required ---
# Anthropic API key (personalization + news research). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Apollo API key (company search + contact enrichment). https://developer.apollo.io/
APOLLO_API_KEY=

# Smartlead API key (campaign + lead loading). https://app.smartlead.ai/app/settings/profile
SMARTLEAD_API_KEY=

# --- Optional ---
# State store. Defaults to local SQLite. Point at Postgres for shared team state, e.g.
#   postgresql+psycopg://user:pass@host:5432/outbound
DATABASE_URL=sqlite:///outbound.db

# Optional web search key for domain correction fallback (DuckDuckGo is used free by default).
SEARCH_API_KEY=
